# AnoSH *nix installer
# (C) Anonoei, Licenced under the MIT license

AINST_SRC="https://github.com/Anonoei/anosh"
AINST_ROOT="${HOME}/.local/anosh"
AINST_CONFIG="${HOME}/.config/anosh"
# ---------------------- #

ANOSH_SHELLS=(bash zsh pwsh)

ARG_SHELL=
ARG_PLUGINS=0
ARG_USER=0
ARG_LOCAL=0

function _show_help {
    echo "AnoSH installer"
    echo " <shell>       : one of (${ANOSH_SHELLS[@]})"
    echo " -h|--help     : show this message"
    echo " -p|--plugins  : delete anosh/plugins"
    echo " -u|--user     : delete user settings"
}

function _parse_args {
    if [[ $# -eq 0 ]]; then
        return
    fi
    AINST_ARG=$1
    shift
    case $AINST_ARG in
        -h|--help)
            _show_help
            exit 0
            ;;
        -p|--plugins)
            ARG_PLUGINS=1
            shift
            ;;
        -u|--user)
            ARG_USER=1
            shift
            ;;
        *)
            echo "Unknown argument! $AINST_ARG"
            exit 1
            ;;
    esac
    _parse_args $*

}

function anosh_remove_plugins {
    if [ -d "${AINST_ROOT}/plugins" ]; then
        rm -rf "${AINST_ROOT}/plugins"
    fi
}
function anosh_remove_user {
    if [ -d "$ANOSH_HOME" ]; then
        rm -rf "$ANOSH_HOME"
    fi
}

function anosh_updaterc {
    # $1 = path to rc
    # $2 = name of shell
    if [ -f "$1" ]; then
        if ! grep -q "^source $AINST_ROOT/src/nix/main $2" "$1"; then
            echo "Updaing $INST_RC..."
            echo "" >> $1
            echo "# --- AnoSH Begin --- #" >> $1
            echo "source $HOME/.local/ash/a.sh" >> $1
            echo "source $AINST_ROOT/src/nix/main $2" >> $1
            echo "# --- AnoSH End--- #" >> $1
            echo "" >> $1
        fi
    else
        touch "$1"
        anosh_updaterc $1 $2
    fi
}

function AINST_CONFIG {
    if [ ! -f "$AINST_CONFIG/anosh.conf" ]; then
        echo "Copying AnoSH configuration"
        cp "$AINST_ROOT/src/nix/anosh.conf.default" "$AINST_CONFIG/anosh.conf"
    fi
}

function anosh_ash {
    if [[ ! -d "$HOME/.config/ash" ]]; then
        echo "Installing ASH"
        $SHELL <(curl -sS "https://raw.githubusercontent.com/anonoei/ash-cli/main/install")
    else
        if ! command -v ash &> /dev/null; then
            echo "ash is installed but not properly sourced?"
        else
            ash update # make sure ash is up to date
        fi
    fi
}

function anosh_pre {
    mkdir -p $AINST_ROOT
    mkdir -p $AINST_CONFIG
    [[ -d "${AINST_ROOT}/src" ]] && rm -rf "${AINST_ROOT}/src"
}
function anosh_post {
    # $1 = shell name
    INST_SHELL=$1
    INST_RC=".${INST_SHELL}rc"
    anosh_updaterc "$HOME/$INST_RC" $INST_SHELL
    AINST_CONFIG
    anosh_ash
}


if [ "${BASH_SOURCE[0]}" -ef "$0" ]
then
    if [[ $# -eq 0 ]]; then
        echo "No shell was provided!"
        _show_help
        exit 2
    else
        ARG_SHELL=$1
        shift
    fi

    if [[ ! ${ANOSH_SHELLS[@]} =~ "$ARG_SHELL" ]]; then
        echo "Unknown shell $ARG_SHELL"
        _show_help
        exit 3
    fi
    _parse_args $*
    echo '    ___               _____ __  __'
    echo '   /   |  ____  ____ / ___// / / /'
    echo '  / /| | / __ \/ __ \\__ \/ /_/ / '
    echo ' / ___ |/ / / / /_/ /__/ / __  /  '
    echo '/_/  |_/_/ /_/\____/____/_/ /_/   '
    if ! command -v git &> /dev/null; then
        echo "Missing required package: git"
        exit 10
    fi

    # echo "Arguments:"
    # echo "shell: $ARG_SHELL"
    # echo "plugins: $ARG_PLUGINS"
    # echo "user: $ARG_USER"

    if [[ $ARG_PLUGINS -eq 1 ]]; then
        anosh_remove_plugins
    fi

    if [[ $ARG_USER -eq 1 ]]; then
        anosh_remove_user
    fi

    anosh_pre
    echo "Cloning AnoSH..."
    git clone $AINST_SRC "${AINST_ROOT}/src"
    anosh_post $ARG_SHELL

    echo -n "Installed! Running AnoSH"
    for _ in {1..5}; do
        sleep .25
        echo -n "."
    done

    echo ""
    exec $SHELL
fi
